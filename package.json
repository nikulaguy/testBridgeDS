{
	"name": "frontguys-accessibility-website",
	"type": "module",
	"version": "0.0.1",
	"scripts": {
		"dev": "astro dev",
		"build": "pnpm build-tokens && astro build",
		"preview": "astro preview",
		"astro": "astro",
		"storybook": "storybook dev -p 6006",
		"build-storybook": "storybook build",
		"build-tokens": "npx tz build",
		"format-files": "pnpm exec biome format --write",
		"lint-files": "pnpm exec biome lint --write",
		"knip": "knip",
		"prepare": "husky"
	},
	"lint-staged": {
		"*.{ts,tsx,js,jsx,astro}": [
			"biome format --write",
			"biome lint --write"
		],
		"*.{json,jsonc}": [
			"biome format --write"
		]
	},
	"dependencies": {
		"@astrojs/check": "^0.9.6",
		"@astrojs/mdx": "^4.3.13",
		"@astrojs/react": "^4.4.2",
		"@astrojs/sitemap": "^3.7.0",
		"astro": "^5.17.2",
		"astro-icon": "^1.1.5",
		"astro-robots-txt": "^1.0.0",
		"class-variance-authority": "^0.7.1",
		"hast-util-to-string": "^3.0.1",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"rehype-external-links": "^3.0.0",
		"remark-directive": "^4.0.0",
		"remark-toc": "^9.0.0",
		"unist-util-visit": "^5.1.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.2",
		"@chromatic-com/storybook": "^4.1.3",
		"@storybook/addon-a11y": "^10.2.9",
		"@storybook/addon-designs": "^11.1.2",
		"@storybook/addon-docs": "^10.2.9",
		"@storybook/addon-vitest": "^10.2.9",
		"@storybook/react-vite": "^10.2.9",
		"@svgr/plugin-jsx": "^8.1.0",
		"@svgr/plugin-svgo": "^8.1.0",
		"@terrazzo/cli": "^0.10.5",
		"@terrazzo/plugin-css": "^0.10.4",
		"@types/node": "^25.2.3",
		"@types/nodemailer": "^7.0.10",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitest/browser-playwright": "^4.0.18",
		"@vitest/coverage-v8": "^4.0.18",
		"culori": "^4.0.2",
		"husky": "^9.1.7",
		"knip": "^5.83.1",
		"lint-staged": "^16.2.7",
		"playwright": "^1.58.2",
		"sass": "^1.97.3",
		"sharp": "^0.34.5",
		"storybook": "^10.2.9",
		"typescript": "^5.9.3",
		"typescript-plugin-css-modules": "^5.2.0",
		"vite-plugin-svgr": "^4.5.0",
		"vitest": "^4.0.18"
	}
}
