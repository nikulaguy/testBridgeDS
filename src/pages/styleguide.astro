import imgGroupeFg1 from "../assets/img/groupe-frontguys-1.jpg";
import imgGroupeFg4 from "../assets/img/groupe-frontguys-4.jpg";
import imgMargaux2x from "../assets/img/margaux@2x.jpg";
import imgMargaux3x from "../assets/img/margaux@3x.jpg";
import imgMargaux from "../assets/img/margaux.jpg";
import Accordion from "../components/Accordion/Accordion.astro";
import Alert from "../components/Alert/Alert.astro";
import Avatar from "../components/Avatar/Avatar.astro";
import Badge from "../components/Badge/Badge.astro";
import BadgeList from "../components/BadgeList/BadgeList.astro";
import Banner from "../components/Banner/Banner.astro";
import { Button } from "../components/Button/Button.tsx";
import Card from "../components/Card/Card.astro";
import ContactExpertBanner from "../components/ContactExpertBanner.astro";
import FormElement from "../components/FormElement/FormElement.astro";
import Input from "../components/Input/Input.astro";
import Link from "../components/Link/Link.astro";
import List from "../components/List/List.astro";
import MediaObject from "../components/MediaObject/MediaObject.astro";
import ProfileBanner from "../components/ProfileBanner/ProfileBanner.astro";
import Section from "../components/Section/Section.astro";
import SectionHeader from "../components/SectionHeader/SectionHeader.astro";
import Stack from "../components/Stack/Stack.astro";
import Text from "../components/Text/Text.astro";
import VisuallyHidden from "../components/VisuallyHidden.astro";
import Layout from "../layouts/Layout.astro";
import { pages } from "../site.config";
import { getCollectionSortedByOrder } from "../utils/collection.utils";

const businessCases = await getCollectionSortedByOrder("businessCases");
