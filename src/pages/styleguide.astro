    </Section>

    <a id="cardlist"></a>
    <Section color="semantic-background-default-alt">
      <SectionHeader title="Card list" />

      <div class="grid">
        {
          businessCases.map(({ id, data: { title, description, imgPath } }) => (
            <Card
              variant="photo"
              title={title}
              subtitle={description}
              url={`${pages.businessCases.path}/${id}`}
              imgPath={imgPath}
            />
          ))
        }
      </div>
    </Section>

    <a id="banner"></a>
    <Section>
      <SectionHeader title="Banner" />
      <Banner aria-label="Prendre rendez-vous">
        <Text as="strong">
          Prenez un rendez-vous de 30 min
        </Text> avec un de nos experts en accessibilité numérique
        <Button
          slot="cta"
          as="a"
          href="https://frontguys.fr/#contact"
          variant="secondary"
          title="Réserver un creneau"
          ><CalendarIcon /> Réserver un créneau</Button
        >
      </Banner>
    </Section>

    <a id="profilebanner"></a>
    <Section>
      <SectionHeader title="Profile Banner" />

      <ProfileBanner
        avatarSrc="/src/assets/img/hamza-iqbal.png"
        title="Banner title"
        name="Person name"
        description="Person occupation"
      >
        <Button slot="cta" as="a" href="#" variant="secondary"
          >Call to action</Button
        >
      </ProfileBanner>

      <ContactExpertBanner />
    </Section>
  </Stack>

  <style>
    .styleguide {
      .l-section {
        &:hover {
          outline: 2px dashed #f00;
        }
      }

      .card-list {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));

        .o-card {
          height: 100%;
        }
      }
    }
