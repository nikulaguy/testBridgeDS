        <FormElement
          name="name"
          labelText="Nom"
          element="input"
          inputType="text"
          placeholder="Nom"
        />
        <FormElement
          name="companyAddress"
          labelText="Votre message"
          element="textarea"
          placeholder="Votre message"
          error="Please set a delivery address"
        />
        <FormElement
          element="select"
          name="formation"
          labelText="Type de formation"
          options={["Design systems", "Design tokens"]}
          value={0}
        />
        <FormElement
          name="consent"
          labelText="En cochant cette case, j'accepte que Frontguys traite mes données personnelles pour m'envoyer des communications en lien avec ses services et contenus (Je peux me désinscrire à tout moment)."
          inputType="checkbox"
        />
        <FormElement
          element="input"
          inputType="checkbox"
          name="formation"
          labelText="Type"
          error={"hi"}
        />
        <FormElement
          element="input"
          inputType="checkbox"
          name="formation"
          labelText="Type"
          link={{
            href: "#",
            label: "En savoir plus",
          }}
        />
      </Stack>
    </Section>

	<a id="alert"></a>
	<Section>
		<SectionHeader title="Alert" />
		<Alert variant="success" text="Alerte de succès" />
		<Alert variant="success" text="Alerte de succès avec description" description="Votre message a été envoyé avec succès." />
		<Alert variant="error" text="Alerte d'erreur" />
		<Alert variant="error" text="Alerte d'erreur avec description" description="Une erreur est survenue lors de l'envoi de votre message." />
	</Section>

    <a id="media"></a>
    <Section>
      <SectionHeader title="Media Object" />
      <MediaObject img={imgGroupeFg1}>
        <SectionHeader
          titleVariant="heading-2"
          title="Notre expertise au service de l'humain"
        >
          <Fragment slot="subtitle"
            >Nous sommes convaincus que la technologie doit servir l'humain, pas
            l'inverse. Notre approche place les utilisateurs au cœur de chaque
            décision.</Fragment
          >
        </SectionHeader>
        <Button>Découvrez notre expertise</Button>
      </MediaObject>

      <MediaObject img={imgGroupeFg1} reversed={true}>
        <SectionHeader
          titleVariant="heading-2"
          title="Notre expertise au service de l'humain"
        >
          <Fragment slot="subtitle"
            >Nous sommes convaincus que la technologie doit servir l'humain, pas
            l'inverse. Notre approche place les utilisateurs au cœur de chaque
