---
import { Image } from "astro:assets";
import imgTestimonialPhoto from "../assets/img/image-2034.png";

import { Button } from "../components/Button/Button.tsx";
import CaseStudyGrid from "../components/CaseStudyGrid/CaseStudyGrid.tsx";
import CreateOpportunity from "../components/CreateOpportunity.astro";
import Section from "../components/Section/Section.astro";
import SectionHeader from "../components/SectionHeader/SectionHeader.astro";
import Stack from "../components/Stack/Stack.astro";
import Text from "../components/Text/Text.astro";
import Layout from "../layouts/Layout.astro";
import { pages } from "../site.config";
import {
	caseStudies,
	expertises,
	sectors,
	gains,
} from "../data/case-studies";

const stats = [
	{ value: "82", label: "missions réalisées" },
	{ value: "+15", label: "clients accompagnés" },
	{ value: "Senior", label: "uniquement" },
];
---

<Layout page={pages.results}>
	<Fragment slot="page-header-cta">
		<Stack axis="x" gap={4} wrap={true}>
			<Button as="a" href={pages.contact.path}>Demandez un diagnostic</Button>
			<Button as="a" href={pages.contact.path} variant="secondary">Parlez à un expert</Button>
		</Stack>
	</Fragment>

	<!-- Section 1: Filterable Case Studies Grid -->
	<Section>
		<CaseStudyGrid
			client:load
			caseStudies={caseStudies}
			expertises={expertises}
			sectors={sectors}
			gains={gains}
		/>
	</Section>

	<!-- Section 2: Stats Row -->
	<Section color="semantic-background-default-alt">
		<div class="stats-row">
			{stats.map(({ value, label }) => (
				<Stack gap={2}>
					<Text as="span" variant="heading-2" color="semantic-foreground-default">
						{value}
					</Text>
					<Text as="span" variant="body-2" color="semantic-foreground-subtle">
						{label}
					</Text>
				</Stack>
			))}
		</div>
	</Section>

	<!-- Section 3: Expert Profiles -->
	<Section>
		<SectionHeader title="Des profils seniors sur chaque mission" />
		<div class="testimonial">
			<Stack gap={6}>
				<Text as="p" variant="heading-6">Lefebvre Dalloz</Text>
				<Text as="blockquote" variant="body-1" class="testimonial__quote">
					"Frontguys a joué un rôle clé dans la transformation digitale de Lefebvre Dalloz. Leurs consultants ont su structurer une fonction Product Design solide, aligner des équipes très diverses et apporter une vraie vision produit à l'échelle du groupe."
				</Text>
				<Stack gap={4} axis="x" align="center">
					<Image
						src={imgTestimonialPhoto}
						alt="Pauline De Certeau"
						class="testimonial__avatar"
						width={88}
						height={88}
					/>
					<Stack gap={1}>
						<Text as="cite" variant="heading-6">Pauline De Certeau</Text>
						<Text variant="body-2">Directrice des produits digitaux</Text>
						<Text variant="caption-1" color="semantic-foreground-subtle">Lefebvre Dalloz</Text>
					</Stack>
				</Stack>
			</Stack>
		</div>
	</Section>

	<!-- CTA Section -->
	<CreateOpportunity
		surtitle="Prochaine étape"
		title="Vous avez trouvé un cas similaire au vôtre ? Parlons de votre contexte."
		subtitle="Un premier échange pour voir si notre approche correspond à votre situation."
		ghostLabel="Parlez à un expert"
		primaryLabel="Demandez un diagnostic"
	/>
</Layout>

<style lang="scss">
	@use "../assets/styles/01-utils/functions" as *;

	/* Stats Row */
	.stats-row {
		display: flex;
		gap: var(--base-space-4);
		width: 100%;

		> * {
			flex: 1;
		}

		@media (max-width: 768px) {
			flex-direction: column;
		}
	}

	/* Testimonial */
	.testimonial {
		max-width: 100%;
		width: 100%;
		padding: var(--base-space-8);
		border: 1px solid var(--semantic-border-subtle);
		border-radius: var(--radius-medium);
		background-color: var(--semantic-background-default);
	}

	.testimonial__quote {
		font-style: normal;
		line-height: 1.6;
	}

	.testimonial__avatar {
		border-radius: var(--radius-circular);
		object-fit: cover;
		flex-shrink: 0;
		width: 88px !important;
		height: 88px !important;
		max-width: 88px;
		max-height: 88px;
	}
</style>
