---
import { Button } from "../../components/Button/Button.tsx";
import BusinessCases from "../../components/BusinessCases.astro";
import List from "../../components/List/List.astro";
import Section from "../../components/Section/Section.astro";
import SectionHeader from "../../components/SectionHeader/SectionHeader.astro";
import Stack from "../../components/Stack/Stack.astro";
import Text from "../../components/Text/Text.astro";
import Layout from "../../layouts/Layout.astro";
import { pages } from "../../site.config";
---

<Layout page={pages.expertiseProcessDesignDev}>
	<Fragment slot="page-header-cta">
		<Stack axis="x" gap={4} wrap={true}>
			<Button as="a" href={pages.contact.path}>Demandez un diagnostic</Button>
			<Button as="a" href="/expertise" variant="secondary">Découvrez toutes nos expertises</Button>
		</Stack>
	</Fragment>

	<!-- Section: Symptômes (fond blanc) -->
	<Section color="semantic-background-default">
		<SectionHeader title="Vous reconnaissez ces symptômes ?">
			<Fragment slot="subtitle">Si l'un de ces signaux vous parle, cette expertise est faite pour vous.</Fragment>
		</SectionHeader>
		<div class="differentiators-grid">
			<div class="differentiator-item">
				<div class="differentiator-separator"></div>
				<Text as="h3" variant="heading-6">Double travail et incompréhensions</Text>
				<Text variant="body-1" color="semantic-foreground-subtle">
					Les designers produisent des maquettes que les développeurs réinterprètent. Résultat : allers-retours, frustrations et dette d'interface.
				</Text>
			</div>
			<div class="differentiator-item">
				<div class="differentiator-separator"></div>
				<Text as="h3" variant="heading-6">Specs livrées trop tôt ou trop tard</Text>
				<Text variant="body-1" color="semantic-foreground-subtle">
					Le handoff design → dev ne tombe jamais au bon moment. Les specs sont incomplètes, obsolètes ou ignorées.
				</Text>
			</div>
			<div class="differentiator-item">
				<div class="differentiator-separator"></div>
				<Text as="h3" variant="heading-6">Standards non appliqués</Text>
				<Text variant="body-1" color="semantic-foreground-subtle">
					Les conventions existent sur le papier mais ne sont pas suivies en pratique. Chaque développeur interprète les maquettes à sa façon.
				</Text>
			</div>
			<div class="differentiator-item">
				<div class="differentiator-separator"></div>
				<Text as="h3" variant="heading-6">Gouvernance floue</Text>
				<Text variant="body-1" color="semantic-foreground-subtle">
					Personne ne sait qui arbitre les décisions d'interface. Les choix se prennent par défaut, sans critère partagé.
				</Text>
			</div>
		</div>
	</Section>

	<!-- Section: Ce que nous observons (fond default-alt) -->
	<Section color="semantic-background-default-alt">
		<div class="two-col-section">
			<div class="two-col-left">
				<Text as="h2" variant="heading-3">Ce que nous observons le plus souvent</Text>
				<Stack gap={4}>
					<Text variant="body-1" color="semantic-foreground-subtle">
						Les frictions entre design et développement ne sont pas des problèmes techniques. Ce sont des problèmes organisationnels — de langage, de synchronisation et de décisions prises au mauvais moment.
					</Text>
					<Text variant="body-1" color="semantic-foreground-subtle">
						Quand designers et développeurs ne partagent pas les mêmes définitions, le nombre d'allers-retours explose et la qualité d'interface s'effondre.
					</Text>
				</Stack>
			</div>
			<div class="two-col-right">
				<List items={[
					"Les allers-retours design/dev consomment 30% du temps de delivery",
					"Le handoff est un point de rupture plutôt qu'un moment de collaboration",
					"Les conventions de nommage et de structure divergent entre Figma et le code",
					"Les décisions d'interface se prennent en silo, sans vision partagée",
					"La dette d'interface s'accumule sans être identifiée ni priorisée",
				]} />
			</div>
		</div>
	</Section>

	<!-- Section: Nos leviers d'intervention (fond blanc) -->
	<Section color="semantic-background-default">
		<div class="two-col-section">
			<div class="two-col-left">
				<Text as="h2" variant="heading-3">Nos leviers d'intervention</Text>
				<Stack gap={4}>
					<Text variant="body-1" color="semantic-foreground-subtle">
						Nous intervenons sur l'interface entre design et développement — jamais d'un seul côté. Chaque levier vise à réduire les frictions et à créer une collaboration fluide.
					</Text>
				</Stack>
				<Button as="a" href="/nos-methodes" variant="secondary">Découvrez nos méthodes</Button>
			</div>
			<div class="two-col-right">
				<div class="posture-list">
					<div class="posture-item">
						<Text as="h3" variant="heading-6">Rituels et synchros</Text>
						<Text variant="body-2" color="semantic-foreground-subtle">Mettre en place des points de synchronisation design/dev réguliers, à des moments clés du cycle.</Text>
					</div>
					<div class="posture-item">
						<Text as="h3" variant="heading-6">Flux de handoff</Text>
						<Text variant="body-2" color="semantic-foreground-subtle">Structurer le passage de relais entre design et développement pour qu'il soit fluide, complet et traçable.</Text>
					</div>
					<div class="posture-item">
						<Text as="h3" variant="heading-6">Standards partagés</Text>
						<Text variant="body-2" color="semantic-foreground-subtle">Aligner les conventions de nommage, de structure et de documentation entre Figma et le code.</Text>
					</div>
					<div class="posture-item">
						<Text as="h3" variant="heading-6">Gouvernance UI/UX</Text>
						<Text variant="body-2" color="semantic-foreground-subtle">Définir qui arbitre quoi, avec quels critères, pour que les décisions d'interface soient tracées et partagées.</Text>
					</div>
				</div>
			</div>
		</div>
	</Section>

	<!-- Section: Ce que nous visons (fond default-alt) -->
	<Section color="semantic-background-default-alt">
		<SectionHeader title="Les résultats que nous visons">
			<Fragment slot="subtitle">Chaque mission est pilotée par des indicateurs concrets, définis dès le cadrage.</Fragment>
		</SectionHeader>
		<div class="three-col-grid">
			<div class="result-item">
				<Text as="h3" variant="heading-6">Vélocité</Text>
				<Text variant="body-1" color="semantic-foreground-subtle">
					Moins d'allers-retours, des specs plus claires, des cycles de livraison plus courts. Le temps gagné se mesure en sprints.
				</Text>
			</div>
			<div class="result-item">
				<Text as="h3" variant="heading-6">Qualité</Text>
				<Text variant="body-1" color="semantic-foreground-subtle">
					Des interfaces conformes aux maquettes, des composants réutilisables et une dette d'interface maîtrisée.
				</Text>
			</div>
			<div class="result-item">
				<Text as="h3" variant="heading-6">Coût</Text>
				<Text variant="body-1" color="semantic-foreground-subtle">
					Le coût caché des frictions design/dev est rendu visible — et les économies sont mesurables dès les premières semaines.
				</Text>
			</div>
		</div>
	</Section>

	<!-- Section: Missions récentes -->
	<Section color="semantic-background-default">
		<SectionHeader title="Missions récentes">
			<Fragment slot="subtitle">Des projets ambitieux, des équipes exigeantes, des résultats mesurables.</Fragment>
		</SectionHeader>
		<BusinessCases />
	</Section>

	<!-- CTA Banner -->
	<Section color="semantic-background-subtle" verticallyCentered={true} gap="static">
		<SectionHeader title="Décrivez votre friction — nous verrons si nous pouvons l'éliminer." titleVariant="heading-2">
			<Fragment slot="surtitle">Prochaine étape</Fragment>
			<Fragment slot="subtitle">Un premier échange pour comprendre votre organisation et identifier les leviers de collaboration les plus impactants.</Fragment>
		</SectionHeader>
		<Stack gap={4} axis="x" wrap={true} justify="center">
			<Button as="a" href={pages.contact.path}>Parlons de vos frictions</Button>
			<Button as="a" href="/expertise" variant="secondary">Découvrez toutes nos expertises</Button>
		</Stack>
	</Section>
</Layout>

<style lang="scss">
	@use "../../assets/styles/01-utils/functions" as *;

	/* Differentiators grid - 2x2 */
	.differentiators-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: var(--base-space-8) var(--base-space-12);
		width: 100%;

		@media (max-width: 768px) {
			grid-template-columns: 1fr;
		}
	}

	.differentiator-item {
		display: flex;
		flex-direction: column;
		gap: var(--base-space-2);
	}

	.differentiator-separator {
		width: 100%;
		height: 1px;
		background-color: var(--semantic-border-subtle, #ccccdb);
		margin-bottom: var(--base-space-4);
	}

	/* Two columns layout */
	.two-col-section {
		display: flex;
		gap: var(--base-space-12, 48px);
		width: 100%;
		align-items: flex-start;

		@media (max-width: 768px) {
			flex-direction: column;
		}
	}

	.two-col-left {
		flex: 1;
		display: flex;
		flex-direction: column;
		gap: var(--base-space-6, 24px);
	}

	.two-col-right {
		flex: 1;
		display: flex;
		flex-direction: column;
	}

	/* Posture list */
	.posture-list {
		display: flex;
		flex-direction: column;
		gap: var(--base-space-6, 24px);
		width: 100%;
	}

	.posture-item {
		display: flex;
		flex-direction: column;
		gap: var(--base-space-1, 4px);
	}

	/* Three columns grid */
	.three-col-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: var(--base-space-8);
		width: 100%;

		@media (max-width: 768px) {
			grid-template-columns: 1fr;
		}
	}

	.result-item {
		display: flex;
		flex-direction: column;
		gap: var(--base-space-2);
	}
</style>
