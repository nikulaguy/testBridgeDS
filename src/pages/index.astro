---
import { Icon } from "astro-icon/components";
import imgGroupFG from "../assets/img/groupe-frontguys-1.jpg";
import BusinessCases from "../components/BusinessCases.astro";
import { Button } from "../components/Button/Button.tsx";
import Card from "../components/Card/Card.astro";
import ContactExpertBanner from "../components/ContactExpertBanner.astro";
import CreateOpportunity from "../components/CreateOpportunity.astro";
import MediaObject from "../components/MediaObject/MediaObject.astro";
import Section from "../components/Section/Section.astro";
import SectionHeader from "../components/SectionHeader/SectionHeader.astro";
import Stack from "../components/Stack/Stack.astro";
import Text from "../components/Text/Text.astro";
import Layout from "../layouts/Layout.astro";
import { pages } from "../site.config";
import { getCollectionSortedByOrder } from "../utils/collection.utils";

const services = await getCollectionSortedByOrder("services");
---

<Layout page={pages.home}>
	<Fragment slot="page-header-cta">
		<Button as="a" href={pages.guideBook.path} variant="secondary">Découvrez notre guide gratuit</Button>
		<Button as="a" href={pages.offer.path}>Découvrez notre offre</Button>
	</Fragment>

	<Section>
		<SectionHeader title="Nous rendons l'accessibilité concrète" />
		<Stack gap={8} axis="y" class="u-full-width">
			<div class="grid" style="--row-gap: var(--col-gap);">
				{
					services.map(({ data: { title, shortDescription }, id }) => {
						const url = id === "audit-conformite" ? pages.audits.path : `${pages.offer.path}#${id}`;
						return (
						<Card
							variant="simple"
							title={title}
							subtitle={shortDescription}
								url={url}
							/>
						)
					})
				}
			</div>
			<ContactExpertBanner as="aside" />
		</Stack>
	</Section>

	<Section color="semantic-background-default-alt">
		<SectionHeader title="Cas client, ce que nous faisons ensemble">
			<Fragment slot="subtitle">Nous accompagnons vos équipes avec la même exigence : rendre le numérique utile à tous.</Fragment>
		</SectionHeader>
		<BusinessCases />
	</Section>

	<CreateOpportunity />

  <Section color="semantic-background-default-alt" verticallyCentered={true}>
		<Stack gap={8}>
			<div class="our-vision_illustration">
				<Icon name="illustration-check" aria-hidden="true" size="100%" />
			</div>

			<Stack as="blockquote" gap={4} align="center">
				<Text as="cite" variant="heading-6">Notre vision</Text>
				<Text variant="heading-4" class="u-text-align:center u-text-wrap:balance">
					“L'accessibilité n'est pas qu’une obligation légale,<span class="u-display:block:md"></span> c'est l’opportunité de créer de meilleures expériences pour tous.”
				</Text>
			</Stack>
		</Stack>
  </Section>

  <Section>
    <MediaObject img={imgGroupFG} reversed={true}>
			<SectionHeader titleVariant="heading-2" title="Nous mettons la technologie au service de l'humain">
				<Fragment slot="subtitle">Mettez vos utilisateurs au cœur de chaque décision. Nous transformons la complexité technique en expériences simples, fluides et accessibles à tous.</Fragment>
			</SectionHeader>
			<Button as="a" href={pages.expertise.path}>Découvrez notre expertise</Button>
    </MediaObject>
  </Section>
</Layout>


<style lang="scss">
	@use "../assets/styles/01-utils/functions" as *;
	.our-vision_illustration {
		aspect-ratio: 120/206;
		text-align: center;
		width: clamp-value(120px, 187px);
		place-self: center;
	}
</style>