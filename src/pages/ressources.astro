---
import { Button } from "../components/Button/Button.tsx";
import Card from "../components/Card/Card.astro";
import CreateOpportunity from "../components/CreateOpportunity.astro";
import Section from "../components/Section/Section.astro";
import SectionHeader from "../components/SectionHeader/SectionHeader.astro";
import Stack from "../components/Stack/Stack.astro";
import Layout from "../layouts/Layout.astro";
import { pages } from "../site.config";
---

<Layout page={pages.resources}>
	<!-- Section 1: Guides & ressources -->
	<Section>
		<SectionHeader title="Nous partageons nos méthodes">
			<Fragment slot="subtitle">Des contenus concrets pour accélérer votre transformation.</Fragment>
		</SectionHeader>
		<div class="grid grid--3col">
			<Card
				variant="simple"
				title="Structurer un design system"
				subtitle="Guide complet pour poser les fondations d'un design system modulaire et gouverné."
				url="/ressources"
			/>
			<Card
				variant="simple"
				title="Collaboration design/dev"
				subtitle="Les rituels, outils et bonnes pratiques pour fluidifier le handoff."
				url="/ressources"
			/>
			<Card
				variant="simple"
				title="Product design & impact"
				subtitle="Comment mesurer l'impact du design sur les résultats business."
				url="/ressources"
			/>
		</div>
	</Section>

	<!-- Section 2: Nos derniers articles -->
	<Section color="semantic-background-default-alt">
		<SectionHeader title="Nos derniers articles" />
		<div class="grid grid--3col grid--articles">
			<Card
				variant="photo"
				title="Quels logiciels facilitent la collaboration designer – développeur ?"
				subtitle="Edit : découvrez notre nouveau site dédié à l'accessibilité : Frontguys A11Y MAJ nov. 2025 – La réponse directe :..."
				imgPath="/src/assets/img/aspectRatio.png"
				url="/ressources"
			/>
			<Card
				variant="photo"
				title="Histoire d'une relation toxique : L'automatisation assistée par IA avec Figma Make"
				subtitle="Au hasard d'un besoin spécifique, j'ai voulu expérimenter l'automatisation via Figma Make. J'ai eu assez vite l'impression de découvrir un..."
				imgPath="/src/assets/img/aspectRatio-1.png"
				url="/ressources"
			/>
			<Card
				variant="photo"
				title="IA : anticiper nos intentions sans sacrifier notre vie privée"
				subtitle="Le vrai challenge qui attend les designers Il y a quelques jours, j'étais concentré sur un document. Vraiment concentré. Et..."
				imgPath="/src/assets/img/aspectRatio-2.png"
				url="/ressources"
			/>
		</div>
	</Section>

	<!-- Section 3: Formations -->
	<Section>
		<SectionHeader title="Formations">
			<Fragment slot="subtitle">Montez en compétence avec nos parcours certifiés.</Fragment>
		</SectionHeader>
		<div class="grid grid--2x2">
			<Card
				variant="simple"
				title="Design system"
				subtitle="Construire, gouverner et faire adopter un design system."
				url="/ressources"
			/>
			<Card
				variant="simple"
				title="Product design"
				subtitle="Cadrage, conception et amélioration continue de vos produits numériques."
				url="/ressources"
			/>
			<Card
				variant="simple"
				title="Accessibilité"
				subtitle="Auditer, accompagner, former, developper."
				url="/ressources"
			/>
			<Card
				variant="simple"
				title="Transformation"
				subtitle="Vision, stratégie, alignement, culture produit, rituels."
				url="/ressources"
			/>
		</div>
	</Section>

	<!-- CTA Section -->
	<CreateOpportunity />
</Layout>

<style lang="scss">
	.grid {
		display: grid;
		width: 100%;
		gap: var(--base-space-6);
	}

	.grid--3col {
		grid-template-columns: repeat(3, 1fr);
		gap: var(--base-space-4);

		@media (max-width: 768px) {
			grid-template-columns: 1fr;
		}
	}

	.grid--articles {
		gap: var(--base-space-8);
	}

	.grid--2x2 {
		grid-template-columns: repeat(2, 1fr);

		@media (max-width: 768px) {
			grid-template-columns: 1fr;
		}
	}
</style>
