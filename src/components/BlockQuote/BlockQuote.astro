---
import "./BlockQuote.scss";
import Stack from "../Stack/Stack.astro";
import Text from "../Text/Text.astro";

interface Props {
	quote: string;
	author: string;
	class?: string;
}

const { quote, author, class: className, ...attrs } = Astro.props;
---

<figure class:list={["c-blockquote", className]} {...attrs}>
	<Stack gap={4}>
		<Text as="blockquote" variant="body-1" class="c-blockquote__text">{quote}</Text>
		<Text as="figcaption" variant="caption-1" class="c-blockquote__author">{author}</Text>
	</Stack>
</figure>
